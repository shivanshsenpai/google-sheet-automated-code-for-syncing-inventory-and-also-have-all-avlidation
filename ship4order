function labelGetInventoryContext_() {
  const ss = SpreadsheetApp.openById(LABEL_INVENTORY_SPREADSHEET_ID);
  const inventorySheet = ss.getSheetByName(LABEL_INVENTORY_SHEET_NAME);
  const matchingSheet = ss.getSheetByName(LABEL_MATCHING_SHEET_NAME);
  const logSheet = ss.getSheetByName(LABEL_LOG_SHEET_NAME) || ss.getSheetByName('Log') || ss.insertSheet(LABEL_LOG_SHEET_NAME);
  if (!inventorySheet || !matchingSheet) {
    throw new Error('Inventory or MatchingTable sheet missing in inventory spreadsheet.');
  }

  const invRows = {};
  const invDataLast = inventorySheet.getLastRow();
  if (invDataLast >= 2) {
    const rows = inventorySheet.getRange(2, 1, invDataLast - 1, 6).getValues();
    for (let i = 0; i < rows.length; i++) {
      const vendorSku = String(rows[i][0] || '').trim();
      if (!vendorSku) continue;
      invRows[labelNormalizeTextKey_(vendorSku)] = {
        row: i + 2,
        stock: Number(rows[i][3]) || 0
      };
    }
  }

  const portalToVendor = {};
  const matchLast = matchingSheet.getLastRow();
  if (matchLast >= 2) {
    const rows = matchingSheet.getRange(2, 1, matchLast - 1, 2).getValues();
    for (let i = 0; i < rows.length; i++) {
      const vendorSku = String(rows[i][0] || '').trim();
      const portalSku = String(rows[i][1] || '').trim();
      if (vendorSku && portalSku) {
        portalToVendor[labelNormalizeTextKey_(portalSku)] = vendorSku;
      }
    }
  }

  return {
    spreadsheet: ss,
    inventorySheet: inventorySheet,
    matchingSheet: matchingSheet,
    logSheet: logSheet,
    invRows: invRows,
    portalToVendor: portalToVendor
  };
}

function labelAppendInventoryLogRows_(logSheet, rowsToLog) {
  if (!rowsToLog || rowsToLog.length === 0) return;
  const startRow = Math.max(logSheet.getLastRow() + 1, 2);
  logSheet.getRange(startRow, 1, rowsToLog.length, rowsToLog[0].length).setValues(rowsToLog);
}

function labelCsvString_(rows) {
  return rows.map(function(r) {
    return r.map(function(c) {
      return '"' + String(c == null ? '' : c).replace(/"/g, '""') + '"';
    }).join(',');
  }).join('\n');
}

function labelGetDriveOutputFolder_() {
  const rootName = 'Label Files';
  const timezone = Session.getScriptTimeZone() || 'Asia/Kolkata';
  const monthName = Utilities.formatDate(new Date(), timezone, 'MMMM yyyy');

  let rootFolders = DriveApp.getRootFolder().getFoldersByName(rootName);
  const root = rootFolders.hasNext() ? rootFolders.next() : DriveApp.getRootFolder().createFolder(rootName);

  let monthFolders = root.getFoldersByName(monthName);
  return monthFolders.hasNext() ? monthFolders.next() : root.createFolder(monthName);
}

function labelCreateCsvDriveFile_(baseName, rows) {
  if (!rows || rows.length <= 1) return null;

  const timezone = Session.getScriptTimeZone() || 'Asia/Kolkata';
  const stamp = Utilities.formatDate(new Date(), timezone, 'yyyyMMdd_HHmmss');
  const fileName = baseName + '_' + stamp + '.csv';
  const blob = Utilities.newBlob(labelCsvString_(rows), 'text/csv', fileName);
  const folder = labelGetDriveOutputFolder_();
  const file = folder.createFile(blob);

  try {
    file.setSharing(DriveApp.Access.ANYONE_WITH_LINK, DriveApp.Permission.VIEW);
  } catch (err) {
    // Domain sharing policies can block this; authorized users can still open the Drive URL.
  }

  return {
    fileId: file.getId(),
    fileName: file.getName(),
    fileUrl: file.getUrl(),
    folderName: folder.getName()
  };
}

function labelBuildInventoryLogRow_(allOrderRow, beforeStock, afterStock) {
  const out = new Array(47).fill('');
  const copyCount = Math.min(allOrderRow.length, 42);
  for (let i = 0; i < copyCount; i++) {
    let val = allOrderRow[i];
    if (val !== null && typeof val === 'object' && Object.prototype.toString.call(val) !== '[object Date]') {
      val = ''; // Scrub CellImage to prevent setValues crash
    }
    out[i] = val;
  }

  if (allOrderRow.length >= 29) out[42] = allOrderRow[28];
  if (allOrderRow.length >= 41) out[43] = allOrderRow[40];

  out[44] = beforeStock;
  out[45] = afterStock;
  out[46] = new Date();
  return out;
}

function labelUpdateAllOrdersReadyToShip_(allOrdersCache, processedOrders) {
  const statusCol = labelGetHeaderColByAliases_(allOrdersCache.headerMap, ['ORDER_STATUS', 'Order Status']);
  const shippingStatusCol = labelGetHeaderColByAliases_(allOrdersCache.headerMap, ['STATUS', 'Shipping Details Status', 'Shipping Details', 'Status']);
  const courierCol = labelGetHeaderColByAliases_(allOrdersCache.headerMap, ['COURIER_NAME', 'Courier Name', 'CourierName']);
  const trackingCol = labelGetHeaderColByAliases_(allOrdersCache.headerMap, ['TRACKING_CODE', 'Tracking Code', 'TrackingCode']);
  if (!statusCol) return 0;

  const touchedRows = {};
  for (let i = 0; i < processedOrders.length; i++) {
    touchedRows[processedOrders[i].allOrder.absRow] = processedOrders[i];
  }

  let updates = 0;
  for (const rowNo in touchedRows) {
    if (!Object.prototype.hasOwnProperty.call(touchedRows, rowNo)) continue;
    const absRow = Number(rowNo);
    const rec = touchedRows[rowNo];
    allOrdersCache.sheet.getRange(absRow, statusCol).setValue('LabelCreated');
    if (shippingStatusCol) {
      allOrdersCache.sheet.getRange(absRow, shippingStatusCol).setValue('Pending Dispatch');
    }
    if (courierCol) {
      allOrdersCache.sheet.getRange(absRow, courierCol).setValue(rec.courierName || '');
    }
    if (trackingCol) {
      allOrdersCache.sheet.getRange(absRow, trackingCol).setValue(rec.trackingCode || '');
    }
    allOrdersCache.sheet.getRange(absRow, 1, 1, allOrdersCache.headers.length).setBackground('#fff2cc');
    updates++;
  }
  return updates;
}

function labelMarkCreateLabelsDone_(createSheet, processedOrders) {
  for (let i = 0; i < processedOrders.length; i++) {
    createSheet.getRange(processedOrders[i].sheetRow, LABEL_COLS.LabelCreated).setValue('Done');
    if (processedOrders[i].courierName) {
      createSheet.getRange(processedOrders[i].sheetRow, LABEL_COLS.COURIER_NAME).setValue(processedOrders[i].courierName);
    }
    createSheet.getRange(processedOrders[i].sheetRow, 1, 1, LABEL_COLS.TRACKING_CODE).setBackground('#fff2cc');
  }
}

function labelMoveDoneRowsToDispatched_() {
  labelEnsureWorkflowSheetStructures_();
  const ss = getMasterSpreadsheet_();
  const createSheet = ss.getSheetByName(LABEL_CREATE_SHEET_NAME);
  const dispatchedSheet = ss.getSheetByName(LABEL_DISPATCHED_SHEET_NAME);
  if (!createSheet || !dispatchedSheet) return { moved: 0 };

  const lastRow = createSheet.getLastRow();
  if (lastRow < 2) return { moved: 0 };

  const rows = createSheet.getRange(2, 1, lastRow - 1, LABEL_COLS.TRACKING_CODE).getValues();
  const appendRows = [];
  const existingKeys = labelBuildDispatchedKeySet_(dispatchedSheet);
  let allOrdersCache = null;
  const allOrderRowsToMark = {};
  const rowsToDelete = [];

  try {
    allOrdersCache = getAllOrdersCache_();
  } catch (err) {
    logEvent_('WARN', 'Could not load All Orders cache while moving Done labels', String(err));
  }

  for (let i = 0; i < rows.length; i++) {
    const labelStatus = String(rows[i][LABEL_COLS.LabelCreated - 1] || '').trim().toLowerCase();
    if (labelStatus !== 'done' && labelStatus !== 'yes') continue;

    const row = rows[i];
    const trackingCode = String(row[LABEL_COLS.TRACKING_CODE - 1] || '').trim();
    if (!trackingCode) continue; 

    createSheet.getRange(i + 2, 1, 1, LABEL_COLS.LabelCreated).setBackground('#fff2cc');
    rowsToDelete.push(i + 2);
    const internalOrderNo = row[LABEL_COLS.INTERNAL_ORDERNO - 1];
    const sku = row[LABEL_COLS.SKU - 1];
    const key = labelBuildInternalSkuKey_(internalOrderNo, sku);
    const courierName = String(row[LABEL_COLS.COURIER_NAME - 1] || '').trim();

    if (allOrdersCache) {
      const allOrder = labelFindAllOrderByInternalSku_(allOrdersCache, internalOrderNo, sku);
      if (allOrder && allOrder.absRow) {
        allOrderRowsToMark[allOrder.absRow] = {
          courierName: courierName,
          trackingCode: trackingCode
        };
      }
    }

    if (!key || existingKeys[key]) continue;

    appendRows.push([
      internalOrderNo,
      sku,
      row[LABEL_COLS.FULLNAME - 1],
      row[LABEL_COLS.ADDRESSLINE1 - 1],
      row[LABEL_COLS.ADDRESSLINE2 - 1],
      row[LABEL_COLS.CITY - 1],
      row[LABEL_COLS.STATE - 1],
      row[LABEL_COLS.PINCODE - 1],
      row[LABEL_COLS.COUNTRY - 1],
      row[LABEL_COLS.PHONE - 1],
      'Pending Dispatch',
      courierName,
      trackingCode
    ]);
    existingKeys[key] = true;
  }

  if (appendRows.length > 0 || rowsToDelete.length > 0) {
    Utilities.sleep(10000);
  }

  if (appendRows.length > 0) {
    const appendStart = Math.max(dispatchedSheet.getLastRow() + 1, 2);
    dispatchedSheet.getRange(appendStart, 1, appendRows.length, LABEL_DISPATCHED_COLS.TRACKING_CODE).setValues(appendRows);
    dispatchedSheet.getRange(appendStart, 1, appendRows.length, LABEL_DISPATCHED_COLS.TRACKING_CODE).setBackground('#fff2cc');
  }

  if (allOrdersCache && allOrdersCache.headers && allOrdersCache.headers.length > 0) {
    const statusCol = labelGetHeaderColByAliases_(allOrdersCache.headerMap, ['ORDER_STATUS', 'Order Status']);
    const shippingStatusCol = labelGetHeaderColByAliases_(allOrdersCache.headerMap, ['STATUS', 'Shipping Details Status', 'Shipping Details', 'Status']);
    const courierCol = labelGetHeaderColByAliases_(allOrdersCache.headerMap, ['COURIER_NAME', 'Courier Name', 'CourierName']);
    const trackingCol = labelGetHeaderColByAliases_(allOrdersCache.headerMap, ['TRACKING_CODE', 'Tracking Code', 'TrackingCode']);
    for (const rowNo in allOrderRowsToMark) {
      if (!Object.prototype.hasOwnProperty.call(allOrderRowsToMark, rowNo)) continue;
      const absRow = Number(rowNo);
      const rec = allOrderRowsToMark[rowNo];
      if (statusCol) {
        allOrdersCache.sheet.getRange(absRow, statusCol).setValue('LabelCreated');
      }
      if (shippingStatusCol) {
        allOrdersCache.sheet.getRange(absRow, shippingStatusCol).setValue('Pending Dispatch');
      }
      if (courierCol) {
        allOrdersCache.sheet.getRange(absRow, courierCol).setValue(rec.courierName || '');
      }
      if (trackingCol) {
        allOrdersCache.sheet.getRange(absRow, trackingCol).setValue(rec.trackingCode || '');
      }
      allOrdersCache.sheet.getRange(absRow, 1, 1, allOrdersCache.headers.length).setBackground('#fff2cc');
    }
  }

  if (rowsToDelete.length > 0) {
    rowsToDelete.sort((a, b) => b - a);
    for (let d = 0; d < rowsToDelete.length; d++) {
      createSheet.deleteRow(rowsToDelete[d]);
    }
  }

  return { moved: appendRows.length };
}

function labelBuildInternalSkuKey_(internalOrderNo, sku) {
  const internalKey = labelNormalizeTextKey_(internalOrderNo);
  const skuKey = labelNormalizeTextKey_(sku);
  if (!internalKey || !skuKey) return '';
  return internalKey + '||' + skuKey;
}

function labelBuildDispatchedKeySet_(dispatchedSheet) {
  const keys = {};
  if (!dispatchedSheet) return keys;

  const lastRow = dispatchedSheet.getLastRow();
  if (lastRow < 2) return keys;

  const rows = dispatchedSheet.getRange(2, 1, lastRow - 1, Math.max(LABEL_DISPATCHED_COLS.INTERNAL_ORDERNO, LABEL_DISPATCHED_COLS.SKU)).getValues();
  for (let i = 0; i < rows.length; i++) {
    const key = labelBuildInternalSkuKey_(
      rows[i][LABEL_DISPATCHED_COLS.INTERNAL_ORDERNO - 1],
      rows[i][LABEL_DISPATCHED_COLS.SKU - 1]
    );
    if (key) keys[key] = true;
  }

  return keys;
}

function precheckCreateLabelRows() {
  try {
    const queue = getCreateLabelRows_();
    const result = {
      rowsReady: queue.rows.length,
      rowsTotal: Math.max(queue.sheet.getLastRow() - 1, 0)
    };
    logEvent_('INFO', 'Create-label precheck complete', result);
    return result;
  } catch (e) {
    logEvent_('ERROR', 'Create-label precheck failed', String(e));
    throw e;
  }
}

function precheckRefundOrders() {
  return precheckCreateLabelRows();
}

function deleteRedRowsFromReadyToShip() {
  return { deletedRows: 0 };
}

function generateAllFiles() {
  const startedAt = new Date();
  logEvent_('INFO', 'Label generation started');

  const queue = getCreateLabelRows_();
  if (queue.rows.length === 0) {
    return {
      shiprocketCsv: '',
      shipglobalCsv: '',
      shiprocketFileUrl: '',
      shipglobalFileUrl: '',
      processedRows: 0,
      movedToDispatched: 0
    };
  }

  const courierConfig = labelParseCourierConfig_();
  const allOrdersCache = getAllOrdersCache_();
  const inventoryCtx = labelGetInventoryContext_();

  const todayDisplay = Utilities.formatDate(new Date(), 'GMT+5:30', 'dd-MM-yyyy');
  const todayIso = Utilities.formatDate(new Date(), 'GMT+5:30', 'yyyy-MM-dd');

  const shiprocketData = [[
    'Order ID', 'Channel', 'Order Date', 'Purpose', 'Currency', 'First Name', 'Last Name',
    'Email', 'Mobile', 'Address 1', 'Address 2', 'Country', 'Postcode', 'City', 'State',
    'Master SKU', 'Product Name', 'HSN Code', 'Quantity', 'Tax', 'VAT', 'Unit Price',
    'Invoice Date', 'Length', 'Breadth', 'Height', 'Weight', 'IOSS', 'EORI', 'Terms',
    'Franchise', 'Seller ID', 'Courier ID'
  ]];

  const shipglobalData = [[
    'invoice_no', 'invoice_date', 'order_reference', 'service', 'package_weight',
    'package_length', 'package_breadth', 'package_height', 'currency_code', 'csb5_status',
    'customer_shipping_firstname', 'customer_shipping_lastname', 'customer_shipping_mobile',
    'customer_shipping_email', 'customer_shipping_company', 'customer_shipping_address',
    'customer_shipping_address_2', 'customer_shipping_address_3', 'customer_shipping_city',
    'customer_shipping_postcode', 'customer_shipping_country_code', 'customer_shipping_state',
    'vendor_order_item_name', 'vendor_order_item_sku', 'vendor_order_item_quantity',
    'vendor_order_item_unit_price', 'vendor_order_item_hsn', 'vendor_order_item_tax_rate',
    'ioss_number', 'csbv5_limit_comfirmation'
  ]];

  const processedOrders = [];
  const stockChanges = {};
  const logRows = [];

  for (let i = 0; i < queue.rows.length; i++) {
    const item = queue.rows[i];
    const allOrder = labelFindAllOrderByInternalSku_(allOrdersCache, item.internalOrderNo, item.sku);
    if (!allOrder) {
      logEvent_('WARN', 'All Orders row not found for create-label row', {
        internalOrderNo: item.internalOrderNo,
        sku: item.sku
      });
      continue;
    }

    const order = {
      internalOrderNo: item.internalOrderNo,
      sku: item.sku,
      qty: Number(labelGetAllOrderValue_(allOrder, ['QTY', 'Qty', 'Quantity'])) || 1,
      salesChannel: labelGetAllOrderValue_(allOrder, ['SALES_CHANNEL', 'Sales Channel']) || '',
      fullName: labelGetAllOrderValue_(allOrder, ['FULLNAME', 'Fullname', 'Full Name']) || item.row[LABEL_COLS.FULLNAME - 1],
      address1: labelGetAllOrderValue_(allOrder, ['ADDRESSLINE1', 'AddressLine1']) || item.row[LABEL_COLS.ADDRESSLINE1 - 1],
      address2: labelGetAllOrderValue_(allOrder, ['ADDRESSLINE2', 'AddressLine2']) || item.row[LABEL_COLS.ADDRESSLINE2 - 1],
      city: labelGetAllOrderValue_(allOrder, ['CITY', 'City']) || item.row[LABEL_COLS.CITY - 1],
      state: labelGetAllOrderValue_(allOrder, ['STATE', 'State']) || item.row[LABEL_COLS.STATE - 1],
      pincode: labelGetAllOrderValue_(allOrder, ['PINCODE', 'Pincode']) || item.row[LABEL_COLS.PINCODE - 1],
      country: labelGetAllOrderValue_(allOrder, ['COUNTRY', 'Country']) || item.row[LABEL_COLS.COUNTRY - 1],
      phone: labelGetAllOrderValue_(allOrder, ['PHONE', 'Phone']) || item.row[LABEL_COLS.PHONE - 1]
    };

    const countryKey = labelNormalizeTextKey_(order.country);
    const isIndia = countryKey === 'india' || countryKey === 'in';
    let included = false;
    let resolvedCourierName = '';

    if (courierConfig.shiprocketCountries.has(countryKey)) {
      shiprocketData.push(labelBuildShiprocketRow_(order, todayDisplay));
      included = true;
      resolvedCourierName = resolvedCourierName || 'Shiprocket';
    }

    if (courierConfig.shipglobalCountries.has(countryKey)) {
      shipglobalData.push(labelBuildShipglobalRow_(order, todayIso, courierConfig.shipglobalCodeMap[countryKey] || ''));
      included = true;
      resolvedCourierName = resolvedCourierName || 'Shipglobal';
    }

    if (isIndia) {
      const salesChannelKey = labelNormalizeTextKey_(order.salesChannel);
      if (salesChannelKey && courierConfig.salesChannelCourierMap[salesChannelKey]) {
        resolvedCourierName = courierConfig.salesChannelCourierMap[salesChannelKey];
      }
    }

    if (!included && !isIndia) {
      logEvent_('WARN', 'Country not mapped in Config for label generation', {
        country: order.country,
        internalOrderNo: order.internalOrderNo,
        sku: order.sku
      });
      continue;
    }

    const vendorSku = inventoryCtx.portalToVendor[labelNormalizeTextKey_(order.sku)] || '';
    if (vendorSku) {
      const invKey = labelNormalizeTextKey_(vendorSku);
      const invRow = inventoryCtx.invRows[invKey];
      if (invRow) {
        const beforeStock = Number(invRow.stock) || 0;
        const afterStock = Math.max(0, beforeStock - (Number(order.qty) || 0));
        invRow.stock = afterStock;
        stockChanges[invKey] = {
          row: invRow.row,
          before: beforeStock,
          after: afterStock,
          vendorSku: vendorSku
        };
        logRows.push(labelBuildInventoryLogRow_(allOrder.row, beforeStock, afterStock));
      } else {
        logRows.push(labelBuildInventoryLogRow_(allOrder.row, '', ''));
      }
    } else {
      logRows.push(labelBuildInventoryLogRow_(allOrder.row, '', ''));
    }

    if (!resolvedCourierName) {
      resolvedCourierName = String(item.row[LABEL_COLS.COURIER_NAME - 1] || '').trim();
    }

    processedOrders.push({
      sheetRow: item.sheetRow,
      internalOrderNo: order.internalOrderNo,
      sku: order.sku,
      courierName: resolvedCourierName,
      trackingCode: String(item.row[LABEL_COLS.TRACKING_CODE - 1] || '').trim(),
      allOrder: allOrder
    });
  }

  for (const key in stockChanges) {
    if (!Object.prototype.hasOwnProperty.call(stockChanges, key)) continue;
    const stock = stockChanges[key];
    inventoryCtx.inventorySheet.getRange(stock.row, 4).setValue(stock.after);
  }

  if (logRows.length > 0) {
    labelAppendInventoryLogRows_(inventoryCtx.logSheet, logRows);
  }

  if (processedOrders.length > 0) {
    labelMarkCreateLabelsDone_(queue.sheet, processedOrders);
    labelUpdateAllOrdersReadyToShip_(allOrdersCache, processedOrders);
  }

  const moved = labelMoveDoneRowsToDispatched_();

  if (typeof syncPendingOrdersToStockcheckRTS_ === 'function') {
    try {
      syncPendingOrdersToStockcheckRTS_(true);
    } catch (syncErr) {
      logEvent_('WARN', 'Queue sync after label generation failed', String(syncErr));
    }
  }

  const shiprocketFile = labelCreateCsvDriveFile_('shiprocket', shiprocketData);
  const shipglobalFile = labelCreateCsvDriveFile_('shipglobal', shipglobalData);

  const summary = {
    processedRows: processedOrders.length,
    movedToDispatched: moved.moved || 0,
    shiprocketRows: Math.max(shiprocketData.length - 1, 0),
    shipglobalRows: Math.max(shipglobalData.length - 1, 0),
    shiprocketFileName: shiprocketFile ? shiprocketFile.fileName : '',
    shipglobalFileName: shipglobalFile ? shipglobalFile.fileName : '',
    durationMs: new Date().getTime() - startedAt.getTime()
  };
  logEvent_('INFO', 'Label generation complete', summary);

  return {
    shiprocketCsv: '',
    shipglobalCsv: '',
    shiprocketFileUrl: shiprocketFile ? shiprocketFile.fileUrl : '',
    shipglobalFileUrl: shipglobalFile ? shipglobalFile.fileUrl : '',
    shiprocketFileName: shiprocketFile ? shiprocketFile.fileName : '',
    shipglobalFileName: shipglobalFile ? shipglobalFile.fileName : '',
    outputFolderName: (shiprocketFile && shiprocketFile.folderName) || (shipglobalFile && shipglobalFile.folderName) || '',
    processedRows: summary.processedRows,
    movedToDispatched: summary.movedToDispatched,
    shiprocketRows: summary.shiprocketRows,
    shipglobalRows: summary.shipglobalRows
  };
}

function labelHandleOnEditFallback_(e) {
  try {
    const sheet = e.source.getActiveSheet();
    const sheetName = sheet.getName();
    const range = e.range;
    const col = range.getColumn();
    const row = range.getRow();
    
    if (sheetName === LABEL_CREATE_SHEET_NAME) {
      if (col !== LABEL_COLS.TRACKING_CODE || row < 2) return;
      
      const newValue = String(e.value || '').trim();
      if (!newValue) return;
      
      const labelCreatedCell = sheet.getRange(row, LABEL_COLS.LabelCreated);
      const labelCreated = String(labelCreatedCell.getValue() || '').trim().toLowerCase();
      if (labelCreated !== 'done' && labelCreated !== 'yes') return;
      
      labelMoveRowToDispatchedOnEdit_(sheet, row, newValue);
      return
