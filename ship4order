function getLogSheet_() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  return ss.getSheetByName('log') || ss.getSheetByName('Log');
}

function logEvent_(level, message, details) {
  const lv = String(level || 'INFO').toUpperCase();
  let text = String(message || '');

  if (details !== undefined && details !== null) {
    if (typeof details === 'string') {
      text += ' | ' + details;
    } else {
      try {
        text += ' | ' + JSON.stringify(details);
      } catch (e) {
        text += ' | [unserializable details]';
      }
    }
  }

  try {
    const logSheet = getLogSheet_();
    if (!logSheet) {
      Logger.log(lv + ': ' + text);
      return;
    }
    logSheet.appendRow([new Date(), lv, text]);
  } catch (e) {
    Logger.log('LOG_WRITE_FAILED: ' + e + ' | ' + lv + ': ' + text);
  }
}

function labelNormalizeHeaderKey_(value) {
  return String(value == null ? '' : value).trim().toLowerCase().replace(/[^a-z0-9]/g, '');
}

function labelNormalizeTextKey_(value) {
  return String(value == null ? '' : value).trim().toLowerCase().replace(/\s+/g, ' ');
}

function labelBuildHeaderMap_(headers) {
  const map = {};
  for (let i = 0; i < headers.length; i++) {
    const key = labelNormalizeHeaderKey_(headers[i]);
    if (key && !Object.prototype.hasOwnProperty.call(map, key)) {
      map[key] = i + 1;
    }
  }
  return map;
}

function labelGetHeaderColByAliases_(headerMap, aliases) {
  for (let i = 0; i < aliases.length; i++) {
    const k = labelNormalizeHeaderKey_(aliases[i]);
    if (Object.prototype.hasOwnProperty.call(headerMap, k)) {
      return headerMap[k];
    }
  }
  return 0;
}

function labelDetectHeaderRowByAliases_(sheet, aliases, maxRowsToScan) {
  if (!sheet) return 1;
  const maxRows = Math.min(maxRowsToScan || 5, sheet.getLastRow());
  const maxCols = sheet.getLastColumn();
  if (maxRows < 1 || maxCols < 1) return 1;

  const aliasSet = {};
  for (let i = 0; i < aliases.length; i++) {
    aliasSet[labelNormalizeHeaderKey_(aliases[i])] = true;
  }

  for (let r = 1; r <= maxRows; r++) {
    const row = sheet.getRange(r, 1, 1, maxCols).getValues()[0];
    for (let c = 0; c < row.length; c++) {
      if (aliasSet[labelNormalizeHeaderKey_(row[c])]) return r;
    }
  }

  return 1;
}

function getMasterSpreadsheet_() {
  const active = SpreadsheetApp.getActiveSpreadsheet();
  if (active.getId() === LABEL_MASTER_SPREADSHEET_ID) return active;
  return SpreadsheetApp.openById(LABEL_MASTER_SPREADSHEET_ID);
}

function labelEnsureSheetMinColumns_(sheet, minCols) {
  if (!sheet) return;
  const maxCols = sheet.getMaxColumns();
  if (maxCols >= minCols) return;
  sheet.insertColumnsAfter(maxCols, minCols - maxCols);
}

function labelEnsureWorkflowSheetStructures_() {
  const ss = getMasterSpreadsheet_();
  const createSheet = ss.getSheetByName(LABEL_CREATE_SHEET_NAME);
  const dispatchedSheet = ss.getSheetByName(LABEL_DISPATCHED_SHEET_NAME);

  if (createSheet) {
    labelEnsureSheetMinColumns_(createSheet, LABEL_COLS.TRACKING_CODE);
    createSheet.getRange(1, 1, 1, LABEL_COLS.TRACKING_CODE).setValues([[
      'INTERNAL_ORDERNO', 'SKU', 'FULLNAME', 'ADDRESSLINE1', 'ADDRESSLINE2',
      'CITY', 'STATE', 'PINCODE', 'COUNTRY', 'PHONE', 'LabelCreated',
      'COURIER_NAME', 'TRACKING_CODE'
    ]]);
  }

  if (dispatchedSheet) {
    labelEnsureSheetMinColumns_(dispatchedSheet, LABEL_DISPATCHED_COLS.TRACKING_CODE);
    dispatchedSheet.getRange(1, 1, 1, LABEL_DISPATCHED_COLS.TRACKING_CODE).setValues([[
      'INTERNAL_ORDERNO', 'SKU', 'FULLNAME', 'ADDRESSLINE1', 'ADDRESSLINE2',
      'CITY', 'STATE', 'PINCODE', 'COUNTRY', 'PHONE', 'DISPACHED_STATUS',
      'COURIER_NAME', 'TRACKING_CODE'
    ]]);
  }
}

function getAllOrdersCache_() {
  labelEnsureWorkflowSheetStructures_();
  const ss = getMasterSpreadsheet_();
  const sheet = ss.getSheetByName(LABEL_ALL_ORDERS_SHEET_NAME);
  if (!sheet) throw new Error('All Orders sheet not found.');

  const headerRow = labelDetectHeaderRowByAliases_(sheet, ['PORTAL_ORDER_ID', 'INTERNAL_ORDERNO', 'ORDER_STATUS'], 6);
  const lastRow = sheet.getLastRow();
  const lastCol = sheet.getLastColumn();
  if (lastRow <= headerRow || lastCol < 1) {
    return {
      sheet: sheet,
      headerRow: headerRow,
      dataStartRow: headerRow + 1,
      headers: [],
      headerMap: {},
      rows: []
    };
  }

  const headers = sheet.getRange(headerRow, 1, 1, lastCol).getValues()[0];
  const headerMap = labelBuildHeaderMap_(headers);
  const dataStartRow = headerRow + 1;
  const rows = sheet.getRange(dataStartRow, 1, lastRow - headerRow, lastCol).getValues();

  return {
    sheet: sheet,
    headerRow: headerRow,
    dataStartRow: dataStartRow,
    headers: headers,
    headerMap: headerMap,
    rows: rows
  };
}

function labelGetAllOrderValue_(cacheEntry, aliases) {
  if (!cacheEntry) return '';
  const headerMap = cacheEntry.headerMap || (cacheEntry.cache ? cacheEntry.cache.headerMap : null);
  const row = cacheEntry.row || [];
  if (!headerMap) return '';
  const col = labelGetHeaderColByAliases_(headerMap, aliases);
  if (!col) return '';
  return row[col - 1];
}

function labelFindAllOrderByInternalSku_(cache, internalOrderNo, sku) {
  const internalCol = labelGetHeaderColByAliases_(cache.headerMap, ['INTERNAL_ORDERNO', 'Internal OrderNo', 'InternalOrderNo']);
  const skuCol = labelGetHeaderColByAliases_(cache.headerMap, ['SKU', 'PortalSKU']);
  if (!internalCol || !skuCol) return null;

  const targetInternal = labelNormalizeTextKey_(internalOrderNo);
  const targetSku = labelNormalizeTextKey_(sku);

  for (let i = 0; i < cache.rows.length; i++) {
    const row = cache.rows[i];
    if (labelNormalizeTextKey_(row[internalCol - 1]) !== targetInternal) continue;
    if (labelNormalizeTextKey_(row[skuCol - 1]) !== targetSku) continue;
    return {
      cache: cache,
      row: row,
      absRow: cache.dataStartRow + i
    };
  }

  for (let j = 0; j < cache.rows.length; j++) {
    const fallback = cache.rows[j];
    if (labelNormalizeTextKey_(fallback[internalCol - 1]) === targetInternal) {
      return {
        cache: cache,
        row: fallback,
        absRow: cache.dataStartRow + j
      };
    }
  }

  return null;
}

function getCreateLabelRows_() {
  labelEnsureWorkflowSheetStructures_();
  const ss = getMasterSpreadsheet_();
  const sheet = ss.getSheetByName(LABEL_CREATE_SHEET_NAME);
  if (!sheet) throw new Error('CreateLabels sheet not found.');

  const lastRow = sheet.getLastRow();
  if (lastRow < 2) return { sheet: sheet, rows: [] };

  const rows = sheet.getRange(2, 1, lastRow - 1, LABEL_COLS.TRACKING_CODE).getValues();
  const out = [];
  for (let i = 0; i < rows.length; i++) {
    const row = rows[i];
    const internalOrderNo = String(row[LABEL_COLS.INTERNAL_ORDERNO - 1] || '').trim();
    const sku = String(row[LABEL_COLS.SKU - 1] || '').trim();
    const labelCreated = String(row[LABEL_COLS.LabelCreated - 1] || '').trim();
    if (!internalOrderNo || !sku) continue;
    if (labelCreated.toLowerCase() === 'done') continue;

    out.push({
      sheetRow: i + 2,
      row: row,
      internalOrderNo: internalOrderNo,
      sku: sku
    });
  }

  return { sheet: sheet, rows: out };
}

function labelParseCourierConfig_() {
  const ss = SpreadsheetApp.getActiveSpreadsheet(); 
  const sheet = ss.getSheetByName(LABEL_CONFIG_SHEET_NAME);
  if (!sheet) throw new Error('Config sheet not found.');

  const values = sheet.getDataRange().getValues();
  const shipglobalCountries = new Set();
  const shipglobalCodeMap = {};
  const shiprocketCountries = new Set();
  const salesChannelCourierMap = {};

  let headerRowIndex = -1;
  let shipglobalCol = -1;
  let shipglobalCCodeCol = -1;
  let shiprocketCol = -1;
  let shiprocketCCodeCol = -1;
  let salesChannelCol = -1;
  let courierNameCol = -1;

  for (let r = 0; r < values.length; r++) {
    const row = values[r];
    let lastFound = '';
    for (let c = 0; c < row.length; c++) {
      const key = labelNormalizeHeaderKey_(row[c]);
      if (key === 'shipglobal') {
        shipglobalCol = c;
        lastFound = 'global';
      } else if (key === 'shiprocket') {
        shiprocketCol = c;
        lastFound = 'rocket';
      } else if (key === 'saleschannel') {
        salesChannelCol = c; 
      } else if (key === 'couriername') {
        courierNameCol = c; 
      } else if (key === 'ccode' || key === 'countrycode') {
        if (lastFound === 'global' && shipglobalCCodeCol === -1) {
          shipglobalCCodeCol = c;
        } else if (lastFound === 'rocket' && shiprocketCCodeCol === -1) {
          shiprocketCCodeCol = c;
        }
      }
    }
    if (shipglobalCol >= 0 || shiprocketCol >= 0) {
      headerRowIndex = r;
      break;
    }
  }

  if (headerRowIndex < 0) {
    return {
      shipglobalCountries: shipglobalCountries,
      shipglobalCodeMap: shipglobalCodeMap,
      shiprocketCountries: shiprocketCountries,
      salesChannelCourierMap: salesChannelCourierMap
    };
  }

  for (let r = headerRowIndex + 1; r < values.length; r++) {
    const row = values[r];
    const globalCountry = shipglobalCol >= 0 ? labelNormalizeTextKey_(row[shipglobalCol]) : '';
    const ccode = shipglobalCCodeCol >= 0 ? String(row[shipglobalCCodeCol] == null ? '' : row[shipglobalCCodeCol]).trim() : '';
    const rocketCountry = shiprocketCol >= 0 ? labelNormalizeTextKey_(row[shiprocketCol]) : '';

    if (globalCountry) {
      shipglobalCountries.add(globalCountry);
      if (ccode) shipglobalCodeMap[globalCountry] = ccode;
    }
    if (rocketCountry) {
      shiprocketCountries.add(rocketCountry);
    }

    if (salesChannelCol >= 0 && courierNameCol >= 0) {
      const salesChannel = labelNormalizeTextKey_(row[salesChannelCol]);
      const courierName = String(row[courierNameCol] == null ? '' : row[courierNameCol]).trim();
      if (salesChannel && courierName) {
        salesChannelCourierMap[salesChannel] = courierName;
      }
    }
  }

  return {
    shipglobalCountries: shipglobalCountries,
    shipglobalCodeMap: shipglobalCodeMap,
    shiprocketCountries: shiprocketCountries,
    salesChannelCourierMap: salesChannelCourierMap
  };
}

function labelSanitizeText(value) {
  if (!value) return '';
  let text = String(value);
  text = text.normalize('NFD').replace(/[\u0300-\u036f]/g, '');
  text = text.replace(/[^a-zA-Z0-9]/g, ' ');
  text = text.replace(/\s+/g, ' ').trim();
  return text;
}

function labelNormalizePhone10_(value) {
  const raw = String(value == null ? '' : value).trim();
  if (!raw) return '';
  const clean = raw.toLowerCase().split('ext')[0].replace(/\D/g, '');
  if (!clean) return '';
  return clean.length > 10 ? clean.slice(-10) : clean.padStart(10, '0');
}

function labelSplitName_(fullName) {
  const text = String(fullName == null ? '' : fullName).trim();
  if (!text) return { first: '', last: '.' };
  const parts = text.split(/\s+/);
  return {
    first: labelSanitizeText(parts[0]),
    last: parts.length > 1 ? labelSanitizeText(parts.slice(1).join(' ')) : '.'
  };
}

